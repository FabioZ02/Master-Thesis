#!/bin/bash

CONFIG_ID=$1
INSTANCE_ID=$2
SEED=$3
INSTANCE=$4

shift 4

OUT=$(./bt_main --main::instance "$INSTANCE" \
                --main::method BSAwr \
                --main::seed "$SEED" \
                --BSAwr::max_evaluations 3000000 \
                --main::irace-enable \
                "$@")

echo "$OUT" | tail -n 1