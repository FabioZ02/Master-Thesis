#!/bin/bash

CONFIG_ID=$1
INSTANCE_ID=$2
SEED=$3
INSTANCE=$4

shift 4

# --- strada B: intercetta i fattori temperatura (non esistono nel binario) ---
START_FACTOR=""
MIN_FACTOR=""
PASS_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --start_temp_factor) START_FACTOR="$2"; shift 2 ;;
        --min_temp_factor)   MIN_FACTOR="$2";   shift 2 ;;
        *) PASS_ARGS+=("$1" "$2"); shift 2 ;;
    esac
done

# --- bigM dell'istanza (identico a BT_Input::ComputeBigM) ---
BIGM=$(python3 -c "
import json
d=json.load(open('$INSTANCE'))
o=d['Orders']; R=d['Resources']; ot=d['OrderTypes'][0]
T=len(o); M=len(R); sq=sum(x['Quantity'] for x in o)
pr=[x['Priority'] for x in o]
print(sq*(M-1)+T*M*max(ot['TargetGroupSize'],ot['MaxGroupSize']-ot['TargetGroupSize'])+T*(max(pr)-min(pr))+1)")

# --- fattori -> temperature assolute, con guardia: min DEVE essere < start ---
START_ABS=$(python3 -c "print(${START_FACTOR:-0.5}*${BIGM})")
MIN_ABS=$(python3 -c "
s=${START_FACTOR:-0.5}*${BIGM}
m=${MIN_FACTOR:-0.0001}*${BIGM}
print(m if m < s else s*0.001)")

./bt_main --main::instance "$INSTANCE" \
          --main::method BSA \
          --main::seed "$SEED" \
          --BSA::max_evaluations 500000 \
          --main::irace-enable \
          --BSA::start_temperature "$START_ABS" \
          --BSA::min_temperature "$MIN_ABS" \
          "${PASS_ARGS[@]}"
